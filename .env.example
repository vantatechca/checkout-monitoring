# Copy this to .env for local development
# Never commit .env to git

# Server / scheduling
PORT=3000
CHECK_INTERVAL_MS=1800000      # 30 min
ALERT_COOLDOWN_MS=3600000      # 1 h — suppress repeat alerts for same ongoing issue
TRIGGER_TOKEN=                 # optional — if set, protected URLs require ?token=<this>

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twilio WhatsApp
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
