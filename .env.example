# Copy this to .env for local development
# Never commit .env to git

# Server / scheduling
PORT=3000
CHECK_INTERVAL_MS=1800000      # 30 min — check cycle cadence
OK_ALERT_INTERVAL_MS=7200000      # 2 h — only send OK heartbeats this often; problems always alert every cycle
ROUTER_STATUS_INTERVAL_MS=14400000 # 4 h — router status digest cadence (manual /router-status bypasses)
HEALTH_CHECK_INTERVAL_MS=14400000  # 4 h — health-check digest cadence (issues + manual /health-check bypass)

# Bridge health-check fetch (used each cycle + on GET /health-check)
BRIDGE_HEALTH_CHECK_URL=https://bridge-7.flystarcafe7.workers.dev/health-check
TRIGGER_TOKEN=                 # optional — if set, protected URLs require ?token=<this>

# Bridge router status fetch (used each cycle + on GET /router-status)
BRIDGE_ROUTER_STATUS_URL=https://bridge-7.flystarcafe7.workers.dev/router/status

# Shared secret the bridge worker sends in X-Alert-Secret when POSTing /alert.
# Leave unset to accept unauthenticated inbound alerts (dev only).
BRIDGE_ALERT_SECRET=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Twilio WhatsApp
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886
ALERT_WHATSAPP_NUMBERS=+19171234567,+16471234567,+63917123456

# Telegram
TELEGRAM_BOT_TOKEN=8471628213:AAFKXBTLhYpwJ_XoLNtfycF8YEEZupTirHw
TELEGRAM_CHAT_IDS=8410946766,7893137983

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Cloudinary (use unsigned preset)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# Google Sheets (optional)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Proxy (optional)
PROXY_SERVER=http://proxy.webshare.io:80
PROXY_USER=your-proxy-user
PROXY_PASS=your-proxy-pass
